    {
        "id": "581ec497659fd1c7",
        "type": "function",
        "z": "c52bfddb800235a9",
        "name": "Prepare SQLite Insert",
        "func": "const payload = msg.measurementPayload;\n\nif (!payload) {\n node.warn(\"Missing measurementPayload, cannot queue\");\n return null;\n}\n\nconst payloadJson = JSON.stringify(payload).replace(/'/g, \"''\");\nconst measuredAt = new Date().toISOString();\nconst measurementId = msg.measurementId\n\nmsg.topic = `\nINSERT OR IGNORE INTO retry_queue (\n  measurementId,\n  payload,\n  measuredAt,\n  retryCount,\n  lastRetryAt\n)\nVALUES (\n  '${measurementId}',\n  '${payloadJson}',\n  '${measuredAt}',\n  0,\n  NULL\n);\n`;\n\nmsg.payload = {};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
