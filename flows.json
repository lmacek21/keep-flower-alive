    {
        "id": "9ad976af50354842",
        "type": "function",
        "z": "98080d677c245485",
        "name": "Store Temp Values",
        "func": "// const topicParts = msg.topic.split(\"/\");\n// const sensorId = topicParts[1];\n// const temperature = Number(msg.payload);\n\n// if (Number.isNaN(temperature)) return null;\n\n// const key = \"tempValues_\" + sensorId;\n// const values = flow.get(key) || [];\n// values.push(temperature);\n// flow.set(key, values);\n\n// const sensorIds = flow.get(\"activeSensorIds\") || [];\n// if (!sensorIds.includes(sensorId)) {\n//     sensorIds.push(sensorId);\n//     flow.set(\"activeSensorIds\", sensorIds);\n// }\n\n// return null;\n\nconst sensorId = msg.sensorId;\nconst temperature = msg.temperature;\n\nconst key = \"tempValues_\" + sensorId;\nconst values = flow.get(key) || [];\nvalues.push(temperature);\nflow.set(key, values);\n\nconst sensorIds = flow.get(\"activeSensorIds\") || [];\nif (!sensorIds.includes(sensorId)) {\n    sensorIds.push(sensorId);\n    flow.set(\"activeSensorIds\", sensorIds);\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 320,
        "wires": [
            []
        ]
    },
