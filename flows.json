    {
        "id": "c97e6a269b97f4ec",
        "type": "function",
        "z": "c52bfddb800235a9",
        "name": "Extract Measurement",
        "func": "const topicParts = msg.topic.split(\"/\");\n// topic: node/{sensorId}/downsampled/thermometer/avg/temperature\nif (topicParts.length < 6) {\n    node.warn(\"Invalid topic: \" + msg.topic);\n    return null;\n}\n\nconst sensorId = topicParts[1];\nconst temperature = Number(msg.payload);\n\nif (Number.isNaN(temperature)) {\n    node.warn(\"Invalid temperature\");\n    return null;\n}\n\nconst measuredAt = new Date().toISOString();\n\nmsg.measurementPayload = {\n    sensorId,\n    temperature,\n    measuredAt\n};\nmsg.measurementId = sensorId +'_'+ measuredAt\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 300,
        "y": 60,
        "wires": [
