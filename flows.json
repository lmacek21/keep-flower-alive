    {
        "id": "eda36893622a6dd1",
        "type": "function",
        "z": "98080d677c245485",
        "name": "function 1",
        "func": "if (msg.statusCode === 404) {\n    return [msg, null];\n}\n\nconst device = msg.payload;\nif (!device.roomId) return [null, null];\n\n\nmsg.payload = { sensorId: msg.sensorId, value: msg.temperature };\nreturn [null, msg];",
