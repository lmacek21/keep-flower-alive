    {
        "id": "59e165a2019e28b5",
        "type": "function",
        "z": "98080d677c245485",
        "name": "Calculate Average Temperature",
        "func": "const sensorIds = flow.get(\"activeSensorIds\") || [];\n\nif (sensorIds.length === 0) return null;\n\nconst messages = [];\n\nfor (const sensorId of sensorIds) {\n    const key = \"tempValues_\" + sensorId;\n    const values = flow.get(key) || [];\n    if (values.length === 0) continue;\n    const avg = values.reduce((a, b) => a + b, 0) / values.length;\n    const avgRounded = Number(avg.toFixed(2));\n    flow.set(key, []);\n    messages.push({\n        topic: `node/${sensorId}/downsampled/thermometer/avg/temperature`,\n        payload: avgRounded\n    });\n}\n\nflow.set(\"activeSensorIds\", []);\n\nreturn messages.length > 0 ? messages : null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 220,
        "wires": [
            [
                "a85446d96a5e016b"
            ]
        ]
    },
