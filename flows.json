        "name": "Dashboard Backend Status",
        "func": "if (msg.statusCode >= 200 &&\n    msg.statusCode < 300) {\n\n    msg.payload = \"ONLINE\";\n\n} else {\n\n    msg.payload = \"OFFLINE\";\n}\n\nreturn msg;",
