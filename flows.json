        "name": "Check Backend Response",
        "func": "const statusCode = msg.statusCode;\n\nif (statusCode >= 200 && statusCode < 300) {\n node.status({\n fill: \"green\",\n shape: \"dot\",\n text: \"sent to backend\"\n });\n\n return [msg, null];\n}\n\nnode.status({\n fill: \"red\",\n shape: \"ring\",\n text: \"backend failed, queueing\"\n});\n\nreturn [null, msg];",
