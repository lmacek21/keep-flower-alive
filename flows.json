        "type": "function",
        "z": "98080d677c245485",
        "name": "Check Gateway Token",
        "func": "const token = global.get(\"gatewayToken\");\nconst expiry = global.get(\"gatewayTokenExp\");\n\nif (token && expiry && Date.now() < expiry) {\n    msg.token = token;\n    return [msg, null];\n}\n\nmsg.payload = {\n    secret: env.get(\"HOUSE_SECRET\"),\n};\n\nreturn [null, msg];",
        "outputs": 2,
