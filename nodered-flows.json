        "z": "2ffe9ee05fe87915",
        "name": "Store Gateway Token",
        "func": "if (!msg.payload || !msg.payload.token) {\n    node.error(\"Gateway login failed: \" + JSON.stringify(msg.payload));\n    return null;\n}\nconst token = msg.payload.token;\nglobal.set(\"gatewayToken\", token);\nglobal.set(\"gatewayTokenExp\", Date.now() + 55 * 60 * 1000);\nmsg.token = token;\nreturn msg;",
