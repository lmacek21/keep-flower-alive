    {
        "id": "ba0f1fdaf8f03089",
        "type": "function",
        "z": "709f64d588efa2f6",
        "name": "Calculate Average Temperature",
        "func": "const sensorIds = flow.get(\"activeSensorIds\") || [];\n\nif (sensorIds.length === 0) return null;\n\nconst messages = [];\n\nfor (const sensorId of sensorIds) {\n    const key = \"tempValues_\" + sensorId;\n    const values = flow.get(key) || [];\n    if (values.length === 0) continue;\n    const avg = values.reduce((a, b) => a + b, 0) / values.length;\n    flow.set(key, []);\n    messages.push({\n        topic: `node/${sensorId}/downsampled/thermometer/avg/temperature`,\n        payload: avg\n    });\n}\n\nflow.set(\"activeSensorIds\", []);\n\nreturn messages.length > 0 ? messages : null;",
        "outputs": 1,
        "noerr": 4,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 220,
        "wires": [
            [
                "f4ebc8abfb9bea22"
            ]
        ]
    },
